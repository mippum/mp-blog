{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":[" "]},"docs":[{"location":"","title":"\ubbf8\uc068\uc5d0\ub4c0 (Mippeum Edu) \ube14\ub85c\uadf8 \ud648","text":""},{"location":"#_1","title":"\ud83c\udd95 \ube14\ub85c\uadf8 \ucd5c\uc2e0 \uae00","text":"<ul> <li>\ubbf8\uc068\uc5d0\ub4c0 \uc18c\uac1c 2026-03-17</li> </ul>"},{"location":"#_2","title":"\ubbf8\uc068\uc5d0\ub4c0 \uc18c\uac1c","text":"<p>\ubbf8\uc068\uc5d0\ub4c0(Mippeum Edu)\ub294 \ud559\uc2b5\uc744 \uc27d\uace0 \ud6a8\uc728\uc801\uc73c\ub85c \ud560 \uc218 \uc788\ub3c4\ub85d \ub3d5\ub294 \uad50\uc721 \ud504\ub85c\uc81d\ud2b8\uc785\ub2c8\ub2e4. \ub2e8\uc21c \uc554\uae30\ubcf4\ub2e4 \uc774\ud574\uc640 \ubc18\ubcf5\uc744 \ud1b5\ud574 \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc775\ud788\ub294 \ubc29\ubc95\uc744 \uc5f0\uad6c\ud558\uace0 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud83d\udc49 \uc790\uc138\ud55c \uc18c\uac1c\ub294 \ubbf8\uc068\uc5d0\ub4c0 \uc18c\uac1c \ud398\uc774\uc9c0\ub97c \ucc38\uace0\ud558\uc138\uc694.</p>"},{"location":"#_3","title":"\ud83d\ude80 \ud559\uc2b5 \uc2dc\uc791\ud558\uae30","text":"<ul> <li>\ud83c\udfa7 \ubc18\ubcf5 \ub4e3\uae30 \ud559\uc2b5 \u2192 \ubbf8\uc068 \ub4e3\uae30 \ud2b8\ub808\uc774\ub108</li> <li>\ud83e\udde0 \ud655\uc778\ud558\uba70 \ud480\uae30 \u2192 \ubbf8\uc068 \ud034\uc988</li> <li>\ud83e\uddd8 \uc790\uae30 \uae0d\uc815 + \uc601\uc5b4 \ud559\uc2b5 \u2192 \uc601\uc5b4 \uae0d\uc815 \ud655\uc5b8</li> <li>\ud83d\udcda \uc774\ud574 \uc911\uc2ec \uc5b4\ud718 \ud559\uc2b5 \u2192 \ubbf8\uc068 \uc601\ub2e8\uc5b4 \uc2dc\ub9ac\uc988</li> </ul> <p>\uc601\uc5b4 \ub2e8\uc5b4\ub97c \uc678\uc6b0\uc9c0 \ub9d0\uace0, \ubc18\ubcf5\uc73c\ub85c \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc775\ud788\uc138\uc694. \ubbf8\uc068\uc5d0\ub4c0\ub294 \ub4e3\uae30\u00b7\ubc18\ubcf5\u00b7\uc774\ud574 \uc911\uc2ec\uc758 \ud559\uc2b5 \uc2dc\uc2a4\ud15c\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud83d\udc49 \uafb8\uc900\ud788 \ud560 \uc218 \uc788\ub294 \uc601\uc5b4 \ud559\uc2b5\uc744 \ubaa9\ud45c\ub85c \ud569\ub2c8\ub2e4.</p>"},{"location":"#_4","title":"\ud83d\udccc \ubbf8\uc068\uc5d0\ub4c0\uc758 \ud2b9\uc9d5","text":""},{"location":"#_5","title":"\u2714 \uc678\uc6b0\uae30\ubcf4\ub2e4 \uc775\ud788\uae30","text":"<p>\ub2e8\uc21c \uc554\uae30 \ub300\uc2e0 \ubc18\ubcf5 \ub178\ucd9c\uacfc \uc774\ud574\ub97c \ud1b5\ud574 \uc790\uc5f0\uc2a4\ub7fd\uac8c \uae30\uc5b5\uc5d0 \ub0a8\ub3c4\ub85d \uc124\uacc4\ud588\uc2b5\ub2c8\ub2e4.</p>"},{"location":"#_6","title":"\u2714 \ub4e3\uae30 \uae30\ubc18 \ubc18\ubcf5 \ud559\uc2b5","text":"<p>TTS(Text-to-Speech)\ub97c \ud65c\uc6a9\ud558\uc5ec \uc5b8\uc81c \uc5b4\ub514\uc11c\ub098 \ud559\uc2b5\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p>"},{"location":"#_7","title":"\u2714 \ubd80\ub2f4 \uc5c6\ub294 \uc9c0\uc18d \uac00\ub2a5\ud55c \uacf5\ubd80","text":"<p>\uc9e7\uac8c\ub77c\ub3c4 \ub9e4\uc77c \uc774\uc5b4\uac08 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ud588\uc2b5\ub2c8\ub2e4.</p>"},{"location":"#_8","title":"\u2714 \ub514\uc9c0\ud138 \ub3c4\uad6c \ud65c\uc6a9","text":"<p>\uc804\uc790\ucc45, \uc624\ub514\uc624, \ud034\uc988 \ub4f1 \ub2e4\uc591\ud55c \ubc29\uc2dd\uc73c\ub85c \ud559\uc2b5\uc744 \uc9c0\uc6d0\ud569\ub2c8\ub2e4.</p>"},{"location":"#_9","title":"\ud83d\udcda \uc81c\uacf5 \ucf58\ud150\uce20","text":""},{"location":"#_10","title":"\ud83d\udcd8 \uc804\uc790\ucc45","text":"<ul> <li>\uc601\uc5b4\ub85c \ud558\ub294 \ubbf8\uc068 \uc790\uae30\uae0d\uc815\ud655\uc5b8  </li> <li>\ubbf8\uc068 1\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac  </li> <li>\ubbf8\uc068 \uc601\ub2e8\uc5b4 Foundation Entry  </li> </ul>"},{"location":"#_11","title":"\ud83d\udee0 \uc628\ub77c\uc778 \uc11c\ube44\uc2a4","text":"<ul> <li>\ud83c\udfa7 \ubbf8\uc068 \ub4e3\uae30 \ud2b8\ub808\uc774\ub108 \u2014 \ubc18\ubcf5 \ub4e3\uae30 \ud559\uc2b5</li> <li>\ud83e\udde0 \ubbf8\uc068 \ud034\uc988 \u2014 \ud655\uc778\ud558\uba70 \ud480\uae30 \ud559\uc2b5</li> </ul>"},{"location":"#_12","title":"\ud83c\udfaf \ubbf8\uc068\uc5d0\ub4c0\uc758 \ubaa9\ud45c","text":"<ul> <li>\uafb8\uc900\ud788 \ud560 \uc218 \uc788\ub294 \ud559\uc2b5  </li> <li>\ubc18\ubcf5\uc73c\ub85c \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc775\ud788\ub294 \ud559\uc2b5  </li> <li>\uae30\uc220\uc744 \ud65c\uc6a9\ud55c \ud6a8\uc728\uc801\uc778 \uacf5\ubd80  </li> <li>\ub204\uad6c\ub098 \uc811\uadfc \uac00\ub2a5\ud55c \ud559\uc2b5 \ud658\uacbd  </li> </ul> <p>\ud559\uc2b5\uc740 \ub2e8\uae30\uac04\uc758 \uc131\uacfc\ubcf4\ub2e4 \uc7a5\uae30\uc801\uc778 \uc2b5\uad00\uc774 \ub354 \uc911\uc694\ud569\ub2c8\ub2e4. \ubbf8\uc068\uc5d0\ub4c0\ub294 \uadf8 \uc2b5\uad00\uc744 \ub9cc\ub4dc\ub294 \uac83\uc744 \ub3d5\uace0\uc790 \ud569\ub2c8\ub2e4.</p> <p>\uc55e\uc73c\ub85c \uc601\uc5b4 \ud559\uc2b5 \ubc29\ubc95, \ub2e8\uc5b4 \ud559\uc2b5 \uc790\ub8cc, \ub3c4\uad6c \ud65c\uc6a9\ubc95 \ub4f1 \uc2e4\uc81c \uacf5\ubd80\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \ucf58\ud150\uce20\ub97c \uc9c0\uc18d\uc801\uc73c\ub85c \uc81c\uacf5\ud560 \uc608\uc815\uc785\ub2c8\ub2e4.</p>"},{"location":"about/","title":"\uc18c\uac1c","text":"<p>\ubbf8\uc068\uc5d0\ub4c0(Mippeum Edu)\ub294 \ud559\uc2b5\uc744 \uc27d\uace0 \ud6a8\uc728\uc801\uc73c\ub85c \ud560 \uc218 \uc788\ub3c4\ub85d \ub3d5\ub294 \uad50\uc721 \ud504\ub85c\uc81d\ud2b8\uc785\ub2c8\ub2e4. \ub2e8\uc21c \uc554\uae30\ubcf4\ub2e4 \uc774\ud574\uc640 \ubc18\ubcf5\uc744 \ud1b5\ud574 \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc775\ud788\ub294 \ubc29\ubc95\uc744 \uc5f0\uad6c\ud558\uace0 \uc81c\uacf5\ud569\ub2c8\ub2e4.</p>"},{"location":"about/#_2","title":"\uc124\ub9bd\uc790 \uc18c\uac1c","text":"<p>\ud559\uc2b5 \uad00\ub828 IT \uac1c\ubc1c\uc790 \ucd9c\uc2e0\uc73c\ub85c, \ud6a8\uc728\uc801\uc778 \ud559\uc2b5 \uc2dc\uc2a4\ud15c\uc744 \uad6c\ucd95\ud558\uace0\uc790 \ubbf8\uc068\uc5d0\ub4c0\ub97c \uc124\ub9bd\ud588\uc2b5\ub2c8\ub2e4. \ub2e4\uc591\ud55c \uc2e4\ud5d8\uacfc \uc5f0\uad6c\ub97c \ud1b5\ud574, \ud559\uc2b5\uc758 \uc9c0\uc18d\uc131\uacfc \ud6a8\uacfc\ub97c \ub192\uc774\ub294 \ubc29\ubc95\uc744 \ucc3e\uc544\uac00\uace0 \uc788\uc2b5\ub2c8\ub2e4.</p>"},{"location":"about/#_3","title":"\ubbf8\uc068\uc5d0\ub4c0\uc758 \ubaa9\ud45c","text":"<ul> <li>\uafb8\uc900\ud788 \ud560 \uc218 \uc788\ub294 \ud559\uc2b5 \ud658\uacbd \uc81c\uacf5  </li> <li>\ubc18\ubcf5 \ud559\uc2b5\uc73c\ub85c \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc775\ud788\uae30  </li> <li>\ub514\uc9c0\ud138 \ub3c4\uad6c\ub97c \ud65c\uc6a9\ud55c \ud6a8\uc728\uc801\uc778 \ud559\uc2b5  </li> <li>\ub204\uad6c\ub098 \uc811\uadfc\ud560 \uc218 \uc788\ub294 \ud559\uc2b5 \uacbd\ud5d8  </li> </ul> <p>\ud559\uc2b5\uc740 \ub2e8\uae30\uac04\uc758 \uc131\uacfc\ubcf4\ub2e4 \uc7a5\uae30\uc801\uc778 \uc2b5\uad00\uc774 \ub354 \uc911\uc694\ud569\ub2c8\ub2e4. \ubbf8\uc068\uc5d0\ub4c0\ub294 \uae30\uc220\uacfc \ucf58\ud150\uce20\ub97c \ud1b5\ud574 \uc774\ub7f0 \uc2b5\uad00 \ud615\uc131\uc744 \ub3d5\uace0\uc790 \ud569\ub2c8\ub2e4.</p>"},{"location":"about/#_4","title":"\ucd9c\ud310 \ucf58\ud150\uce20","text":""},{"location":"about/#_5","title":"\uc601\uc5b4\ub85c \ud558\ub294 \ubbf8\uc068 \uc790\uae30\uae0d\uc815\ud655\uc5b8","text":"<p>\uc790\uae30 \uae0d\uc815 \ud655\uc5b8\uc744 \uc601\uc5b4 \ubb38\uc7a5\uc73c\ub85c \uad6c\uc131\ud55c \uc804\uc790\ucc45\uc785\ub2c8\ub2e4. \ubb38\uc7a5\uc744 \ubc18\ubcf5\ud558\uba70 \uba85\uc0c1\ud558\uba74 \uc790\uc874\uac10\uc744 \ub192\uc774\uace0 \uc601\uc5b4\uc5d0\ub3c4 \uc775\uc219\ud574\uc9c0\ub3c4\ub85d \uc124\uacc4\ub418\uc5c8\uc2b5\ub2c8\ub2e4.  </p>"},{"location":"about/#11","title":"\ubbf8\uc068 1\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac","text":"<p>\uc804\uce58\uc0ac \ud45c\ud604\uc740 \uad00\uc6a9\uc801 \ud45c\ud604\uc774 \ub9ce\uc544 \ub9d0\ud560 \ub54c \ubc14\ub85c \ub098\uc624\uae30 \uc5b4\ub835\uc2b5\ub2c8\ub2e4. TTS\ub97c \ud65c\uc6a9\ud574 \ubc18\ubcf5 \ud559\uc2b5\ud558\ub3c4\ub85d \uc81c\uc791\ud558\uc5ec, \uc27d\uac8c \ub4e3\uace0 \uc678\uc6b8 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p>"},{"location":"about/#foundation-entry","title":"\ubbf8\uc068 \uc601\ub2e8\uc5b4 Foundation Entry","text":"<p>\ub2e8\uc5b4\ub97c \uc678\uc6b0\ub294 \ub300\uc2e0, \ubb38\uc7a5\uacfc \uc774\ubbf8\uc9c0, \ubc1c\uc74c\uc744 \ud1b5\ud574 \uc774\ud574\ud558\uba70 \ud559\uc2b5\ud569\ub2c8\ub2e4. AI\ub97c \ubcf4\uc870 \ub3c4\uad6c\ub85c \ud65c\uc6a9\ud574 \ud559\uc2b5 \ud6a8\uc728\uc744 \ub192\uc778 \ud604\ub300\uc801 \uc601\uc5b4 \ub2e8\uc5b4 \ud559\uc2b5\uc11c\uc785\ub2c8\ub2e4.</p>"},{"location":"about/#_6","title":"\uc628\ub77c\uc778 \uc11c\ube44\uc2a4","text":""},{"location":"about/#_7","title":"\ubbf8\uc068 \ub4e3\uae30 \ud2b8\ub808\uc774\ub108","text":"<p>\ud2b9\uc815 \ubb38\uad6c\ub97c \ubc18\ubcf5\ud574\uc11c \ub4e4\uc73c\uba70 \uc554\uae30\ud558\uac70\ub098 \uba85\uc0c1\ud560 \uc218 \uc788\ub294 \uc11c\ube44\uc2a4\uc785\ub2c8\ub2e4.</p>"},{"location":"about/#_8","title":"\ubbf8\uc068 \ud034\uc988","text":"<p>\ud55c \ubb38\uc81c\uc529 \ub2f5\uc744 \ud655\uc778\ud558\uba70 \ud559\uc2b5\ud560 \uc218 \uc788\ub294 \ud034\uc988 \uc11c\ube44\uc2a4\ub85c, \ubd80\ub2f4 \uc5c6\uc774 \ubc18\ubcf5 \ud559\uc2b5\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4.</p>"},{"location":"blog/","title":"\ube14\ub85c\uadf8 \uae00","text":""},{"location":"blog/2026/03/17/%EB%AF%B8%EC%81%A8%EC%97%90%EB%93%80-%EC%86%8C%EA%B0%9C/","title":"\ubbf8\uc068\uc5d0\ub4c0 \uc18c\uac1c","text":"<p>\ubbf8\uc068\uc5d0\ub4c0(Mippeum Edu)\ub294 \ud6a8\uc728\uc801\uc778 \ud559\uc2b5 \uc2dc\uc2a4\ud15c\uc744 \ub9cc\ub4e4\uae30 \uc704\ud574 \uc2dc\uc791\ub41c \uad50\uc721 \ud504\ub85c\uc81d\ud2b8\uc785\ub2c8\ub2e4. \ud2b9\ud788 \ubc18\ubcf5 \ud559\uc2b5\uacfc \ub514\uc9c0\ud138 \ub3c4\uad6c\ub97c \ud65c\uc6a9\ud558\uc5ec, \ub204\uad6c\ub098 \ubd80\ub2f4 \uc5c6\uc774 \uafb8\uc900\ud788 \uacf5\ubd80\ud560 \uc218 \uc788\ub294 \ud658\uacbd\uc744 \ub9cc\ub4dc\ub294 \uac83\uc744 \ubaa9\ud45c\ub85c \ud569\ub2c8\ub2e4.</p> <p>\ud559\uc2b5\uc740 \ub2e8\uc21c\ud55c \uc758\uc9c0\ub098 \ub178\ub825\ub9cc\uc73c\ub85c \uc9c0\uc18d\ub418\uae30 \uc5b4\ub835\uc2b5\ub2c8\ub2e4. \ubbf8\uc068\uc5d0\ub4c0\ub294 \uae30\uc220\uacfc \ucf58\ud150\uce20\ub97c \uacb0\ud569\ud558\uc5ec \u201c\uacc4\uc18d\ud560 \uc218 \uc788\ub294 \ud559\uc2b5\u201d\uc744 \uc124\uacc4\ud569\ub2c8\ub2e4.</p>"},{"location":"blog/2026/03/17/%EB%AF%B8%EC%81%A8%EC%97%90%EB%93%80-%EC%86%8C%EA%B0%9C/#_2","title":"\uc124\ub9bd \ubc30\uacbd","text":"<p>\ubbf8\uc068\uc5d0\ub4c0\ub294 \ud559\uc2b5 \uad00\ub828 IT \uac1c\ubc1c \uacbd\ud5d8\uc744 \ubc14\ud0d5\uc73c\ub85c \uc124\ub9bd\ub418\uc5c8\uc2b5\ub2c8\ub2e4. \ud6a8\uc728\uc801\uc778 \ud559\uc2b5 \uc2dc\uc2a4\ud15c\uc744 \uad6c\ucd95\ud558\uae30 \uc704\ud574 \ub2e4\uc591\ud55c \uc2e4\ud5d8\uacfc \uc5f0\uad6c\ub97c \uc9c4\ud589\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.</p> <p>\ucd5c\uadfc\uc5d0\ub294 \uc804\uc790\ucc45\uc758 TTS(Text-to-Speech)\ub97c \ud65c\uc6a9\ud55c \ubc18\ubcf5 \ud559\uc2b5 \ubc29\ubc95\uc744 \uc911\uc810\uc801\uc73c\ub85c \uc5f0\uad6c\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ub4e3\uae30\u00b7\ubc18\ubcf5\u00b7\uc790\ub3d9\ud654\ub97c \ud65c\uc6a9\ud558\uba74 \ud559\uc2b5 \ubd80\ub2f4\uc744 \ud06c\uac8c \uc904\uc774\uba74\uc11c\ub3c4 \ud6a8\uacfc\ub97c \ub192\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p>"},{"location":"blog/2026/03/17/%EB%AF%B8%EC%81%A8%EC%97%90%EB%93%80-%EC%86%8C%EA%B0%9C/#_3","title":"\ubbf8\uc068\uc5d0\ub4c0\uc758 \ubaa9\ud45c","text":"<p>\ubbf8\uc068\uc5d0\ub4c0\ub294 \ub2e4\uc74c\uacfc \uac19\uc740 \ud559\uc2b5 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud558\uace0\uc790 \ud569\ub2c8\ub2e4.</p> <ul> <li>\uafb8\uc900\ud788 \uacc4\uc18d\ud560 \uc218 \uc788\ub294 \ud559\uc2b5  </li> <li>\ubc18\ubcf5\uc744 \ud1b5\ud574 \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc775\ud788\ub294 \ud559\uc2b5  </li> <li>\ub514\uc9c0\ud138 \ub3c4\uad6c\ub97c \ud65c\uc6a9\ud55c \ud6a8\uc728\uc801\uc778 \ud559\uc2b5  </li> <li>\ub204\uad6c\ub098 \uc811\uadfc \uac00\ub2a5\ud55c \ud559\uc2b5 \ud658\uacbd  </li> </ul> <p>\ud559\uc2b5\uc740 \ub2e8\uae30\uac04\uc758 \uc131\uacfc\ubcf4\ub2e4 \uc7a5\uae30\uc801\uc778 \uc2b5\uad00\uc774 \ub354 \uc911\uc694\ud569\ub2c8\ub2e4. \ubbf8\uc068\uc5d0\ub4c0\ub294 \uae30\uc220\uacfc \ucf58\ud150\uce20\ub97c \ud1b5\ud574 \uc774\ub7ec\ud55c \uc2b5\uad00 \ud615\uc131\uc744 \ub3d5\ub294 \uac83\uc744 \ubaa9\ud45c\ub85c \ud569\ub2c8\ub2e4.</p>"},{"location":"blog/2026/03/17/%EB%AF%B8%EC%81%A8%EC%97%90%EB%93%80-%EC%86%8C%EA%B0%9C/#_4","title":"\ucd9c\ud310 \ucf58\ud150\uce20","text":""},{"location":"blog/2026/03/17/%EB%AF%B8%EC%81%A8%EC%97%90%EB%93%80-%EC%86%8C%EA%B0%9C/#_5","title":"\uc601\uc5b4\ub85c \ud558\ub294 \ubbf8\uc068 \uc790\uae30\uae0d\uc815\ud655\uc5b8","text":"<p>\uc790\uae30 \uae0d\uc815 \ud655\uc5b8\uc744 \uc601\uc5b4 \ubb38\uc7a5\uc73c\ub85c \uad6c\uc131\ud55c \ucc45\uc785\ub2c8\ub2e4. \uc815\ud574\uc9c4 \uae0d\uc815 \ubb38\uc7a5\uc744 \ubc18\ubcf5\ud558\uba70 \uba85\uc0c1\ud560 \uc218 \uc788\ub3c4\ub85d \ub9cc\ub4e4\uc5b4\uc84c\uc73c\uba70, \uc790\uc874\uac10\uc744 \ub192\uc774\uace0 \uc0b6\uc744 \uae0d\uc815\uc801\uc73c\ub85c \ubc14\ub77c\ubcf4\ub294 \ub370 \ub3c4\uc6c0\uc744 \uc90d\ub2c8\ub2e4.</p> <p>\uc601\uc5b4 \ubb38\uc7a5\uc73c\ub85c \uad6c\uc131\ub418\uc5b4 \uc788\uae30 \ub54c\ubb38\uc5d0 \ubc18\ubcf5\ud560\uc218\ub85d \uc601\uc5b4\uc5d0\ub3c4 \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc775\uc219\ud574\uc9d1\ub2c8\ub2e4. \uc804\uc790\ucc45\uc758 \uc77d\uc5b4\uc8fc\uae30 \uae30\ub2a5\uc744 \ud65c\uc6a9\ud558\uba74 \uc190\uc27d\uac8c \ubc18\ubcf5 \uba85\uc0c1\uc744 \ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p>"},{"location":"blog/2026/03/17/%EB%AF%B8%EC%81%A8%EC%97%90%EB%93%80-%EC%86%8C%EA%B0%9C/#11","title":"\ubbf8\uc068 1\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac","text":"<p>TTS \ubc18\ubcf5\uc73c\ub85c \uc785\uc5d0 \ucc29 \ub2ec\ub77c\ubd99\ub294</p> <p>\uc804\uce58\uc0ac \ud45c\ud604\uc740 \uc77d\uae30\ubcf4\ub2e4 \ub9d0\ud558\uae30\uc640 \uc4f0\uae30\uc5d0\uc11c \ub354 \uc5b4\ub824\uc6b4 \uc601\uc5ed\uc785\ub2c8\ub2e4. \ub9ce\uc740 \ud45c\ud604\uc774 \uad00\uc6a9\uc801\uc774\uae30 \ub54c\ubb38\uc5d0 \ubc18\ubcf5 \ud559\uc2b5\uc774 \ud544\uc218\uc801\uc785\ub2c8\ub2e4.</p> <p>\uc774 \ucc45\uc740 TTS \uae30\ub2a5\uc744 \ud65c\uc6a9\ud558\uc5ec \ub4e4\uc73c\uba74\uc11c \ubc18\ubcf5 \ud559\uc2b5\ud560 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ub418\uc5c8\uc2b5\ub2c8\ub2e4. \uc548\ub4dc\ub85c\uc774\ub4dc Play \ubd81\uc758 \u201c\uc18c\ub9ac \ub0b4\uc5b4 \uc77d\uae30\u201d \uae30\ub2a5\uc744 \uc0ac\uc6a9\ud558\uba74 \ube60\ub974\uace0 \ud3b8\ud558\uac8c \ud559\uc2b5\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <p>\ubc18\ubcf5 \ud559\uc2b5\uc744 \ud1b5\ud574 \uc804\uce58\uc0ac \ud45c\ud604\uc5d0 \ub300\ud55c \uc790\uc2e0\uac10\uc744 \ud0a4\uc6b8 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p>"},{"location":"blog/2026/03/17/%EB%AF%B8%EC%81%A8%EC%97%90%EB%93%80-%EC%86%8C%EA%B0%9C/#foundation-entry","title":"\ubbf8\uc068 \uc601\ub2e8\uc5b4 Foundation Entry","text":"<p>\ucc98\uc74c\uc73c\ub85c \uc2dc\uc791\ud558\ub294 \ubbf8\uc068 \uc601\ub2e8\uc5b4</p> <p>\ub2e8\uc21c \uc554\uae30\uac00 \uc544\ub2c8\ub77c \uc774\ud574 \uae30\ubc18\uc758 \uc5b4\ud718 \ud559\uc2b5\uc744 \ubaa9\ud45c\ub85c \ud569\ub2c8\ub2e4.</p> <p>\uac01 \ub2e8\uc5b4\ub294 \uc2e4\uc81c \ubb38\uc7a5 \uc18d\uc5d0\uc11c \uc81c\uc2dc\ub418\uba70, \uc9c1\uad00\uc801\uc778 \uc774\ubbf8\uc9c0\uc640 \ud568\uaed8 \uc81c\uacf5\ub429\ub2c8\ub2e4. \uc601\uc601\uc0ac\uc804 \uc815\uc758\uc640 \ud55c\uad6d\uc5b4 \ub73b\uc744 \ud568\uaed8 \uc81c\uacf5\ud558\uc5ec \uc758\ubbf8\ub97c \uc815\ud655\ud788 \uc774\ud574\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ubc1c\uc74c \uc74c\uc131 \uae30\ub2a5\uc744 \ud1b5\ud574 \uc790\uc5f0\uc2a4\ub7ec\uc6b4 \uc601\uc5b4 \uc18c\ub9ac\uc5d0\ub3c4 \uc775\uc219\ud574\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <p>AI \uae30\uc220\uc744 \ubcf4\uc870 \ub3c4\uad6c\ub85c \ud65c\uc6a9\ud558\uc5ec \ud559\uc2b5 \ud6a8\uc728\uc744 \ub192\uc778 \ud604\ub300\uc801\uc778 \uc601\uc5b4 \ub2e8\uc5b4 \ud559\uc2b5\uc11c\uc785\ub2c8\ub2e4.</p>"},{"location":"blog/2026/03/17/%EB%AF%B8%EC%81%A8%EC%97%90%EB%93%80-%EC%86%8C%EA%B0%9C/#_6","title":"\uc628\ub77c\uc778 \uc11c\ube44\uc2a4","text":""},{"location":"blog/2026/03/17/%EB%AF%B8%EC%81%A8%EC%97%90%EB%93%80-%EC%86%8C%EA%B0%9C/#_7","title":"\ubbf8\uc068 \ub4e3\uae30 \ud2b8\ub808\uc774\ub108","text":"<p>\ud2b9\uc815 \ubb38\uad6c\ub97c \ubc18\ubcf5\ud574\uc11c \ub4e4\uc73c\uba70 \uc554\uae30\ud558\uac70\ub098 \uba85\uc0c1\ud560 \uc218 \uc788\ub294 \uc11c\ube44\uc2a4\uc785\ub2c8\ub2e4. \ubc18\ubcf5 \ub4e3\uae30\ub97c \ud1b5\ud574 \uc790\uc5f0\uc2a4\ub7fd\uac8c \uae30\uc5b5\uc5d0 \ub0a8\ub3c4\ub85d \ub3d5\uc2b5\ub2c8\ub2e4.</p>"},{"location":"blog/2026/03/17/%EB%AF%B8%EC%81%A8%EC%97%90%EB%93%80-%EC%86%8C%EA%B0%9C/#_8","title":"\ubbf8\uc068 \ud034\uc988","text":"<p>\ud55c \ubb38\uc81c\uc529 \ub2f5\uc744 \ud655\uc778\ud558\uba70 \ud559\uc2b5\ud560 \uc218 \uc788\ub294 \ud034\uc988 \uc11c\ube44\uc2a4\uc785\ub2c8\ub2e4. \ubd80\ub2f4 \uc5c6\uc774 \ubc18\ubcf5 \ud559\uc2b5\uc744 \uc9c4\ud589\ud560 \uc218 \uc788\ub3c4\ub85d \uc124\uacc4\ub418\uc5c8\uc2b5\ub2c8\ub2e4.</p> <p>\uc55e\uc73c\ub85c \uc774 \ube14\ub85c\uadf8\uc5d0\uc11c\ub294 \uc601\uc5b4 \ud559\uc2b5 \ubc29\ubc95, \ub2e8\uc5b4 \ud559\uc2b5 \uc790\ub8cc, \ud559\uc2b5 \ub3c4\uad6c \ud65c\uc6a9\ubc95 \ub4f1 \uc2e4\uc81c \uacf5\ubd80\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \ub2e4\uc591\ud55c \ucf58\ud150\uce20\ub97c \uc9c0\uc18d\uc801\uc73c\ub85c \uc81c\uacf5\ud560 \uc608\uc815\uc785\ub2c8\ub2e4.</p>"},{"location":"blog/archive/2026/","title":"2026","text":""}]}